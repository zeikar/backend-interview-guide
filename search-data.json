---
layout: null
permalink: /search-data.json
---
[
{% assign comma = "" %}
{% for page in site.html_pages %}
  {% assign include_page = false %}
  {% assign is_root_page = page.path == "README.md" %}
  {% assign is_section_page = page.name == "README.md" and page.dir != "/" %}
  {% assign is_article_page = page.name != "README.md" and page.path contains "/" %}
  {% if is_root_page or is_section_page or is_article_page %}
    {% assign include_page = true %}
  {% endif %}
  {% if page.name == "AGENTS.md" or page.name == "CLAUDE.md" or page.path contains "_workspace/" %}
    {% assign include_page = false %}
  {% endif %}
  {% if page.search_exclude == true %}
    {% assign include_page = false %}
  {% endif %}
  {% if include_page %}
    {% assign kind = "article" %}
    {% assign category = page.parent | default: "" %}
    {% if is_root_page %}
      {% assign kind = "home" %}
      {% assign category = "홈" %}
    {% elsif is_section_page %}
      {% assign kind = "section" %}
      {% assign category = page.title | default: page.name %}
    {% endif %}
{{ comma }}  {
    "title": {{ page.title | default: page.name | jsonify }},
    "url": {{ page.url | relative_url | jsonify }},
    "description": {{ page.description | default: "" | jsonify }},
    "category": {{ category | jsonify }},
    "kind": {{ kind | jsonify }},
    "content": {{ page.content | strip_html | strip_newlines | replace: "  ", " " | jsonify }}
  }
    {% assign comma = "," %}
  {% endif %}
{% endfor %}
]
